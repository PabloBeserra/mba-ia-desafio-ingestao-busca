# Chave de API (OpenAI)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-5-nano

# Chave de API (Gemini)
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL=models/embedding-001
GOOGLE_LLM_MODEL=gemini-2.5-flash-lite

# Provedores em uso: openai ou gemini
EMBEDDING_PROVIDER=openai
LLM_PROVIDER=openai

# Banco vetorial (Postgres + pgvector)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag
PG_VECTOR_COLLECTION_NAME=pdf_chunks

# Arquivo PDF (opcional - default: ./document.pdf)
PDF_PATH=

# Opcional: true para recriar a collection a cada ingestao
PRE_DELETE_COLLECTION=false

# Variaveis legadas (compatibilidade com scripts antigos)
PGVECTOR_URL=
PGVECTOR_COLLECTION=